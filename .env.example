THESADA_HTTP_ADDR=:8080
THESADA_DATABASE_URL=postgres://thesada_app:CHANGEME@127.0.0.1:5432/thesada_app?sslmode=disable
THESADA_BASE_URL=http://localhost:8080
THESADA_COOKIE_SECRET=replace-with-32-bytes-base64

THESADA_MQTT_URL=tls://mqtt.thesada.app:8883
THESADA_MQTT_USER=thesada-app
THESADA_MQTT_PASS=
THESADA_MQTT_CLIENT_ID=thesada-app-dev
THESADA_MQTT_TOPIC_ROOT=thesada

THESADA_SMTP_HOST=
THESADA_SMTP_PORT=587
THESADA_SMTP_USER=
THESADA_SMTP_PASS=
THESADA_SMTP_FROM=alerts@thesada.app

THESADA_TELEGRAM_BOT_TOKEN=

# Reverse proxy IPs/CIDRs, comma-separated; forwarded headers are only
# honoured from these peers. Empty for direct/dev use.
THESADA_TRUSTED_PROXIES=

# Encrypts the on-disk CA private key (ca.key) with AES-256-GCM under a
# scrypt-derived key. Empty = legacy plaintext PEM on disk + startup
# warning. To migrate an existing plaintext install:
#   1. set THESADA_CA_KEY_PASSPHRASE here
#   2. run `thesada-app ca-encrypt`
#   3. verify the next normal start logs "CA loaded" without the warning
#   4. delete ca.key.plaintext.bak
THESADA_CA_KEY_PASSPHRASE=
