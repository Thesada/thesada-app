# thesada-app config. Copy to app.env and fill the blanks (startup.sh does this).

# Database (the timescaledb service). Password must match db.env.
THESADA_DATABASE_URL=postgres://thesada_app:CHANGEME_DB_PASSWORD@timescaledb:5432/thesada_app?sslmode=disable
# Optional separate admin / mqtt-ingest roles; default to the URL above.
THESADA_DATABASE_URL_ADMIN=
THESADA_DATABASE_URL_MQTT=

# Session cookie signing key, 32+ random bytes (startup.sh generates one).
THESADA_COOKIE_SECRET=

# MQTT broker (the mosquitto service).
THESADA_MQTT_URL=mqtt://mosquitto:1883
THESADA_MQTT_USER=
THESADA_MQTT_PASS=
THESADA_MQTT_TOPIC_ROOT=thesada

# Device CA dir + passphrase that encrypts the on-disk CA key (startup.sh generates one).
THESADA_CA_DIR=/opt/thesada-app/ca
THESADA_CA_KEY_PASSPHRASE=

# Public base URL for magic-link emails. Set to the URL clients reach.
THESADA_BASE_URL=http://localhost:8080

# First super-admin. On boot a one-shot reset link is logged to stdout.
THESADA_ADMIN_EMAIL=

# SMTP for magic-link / reset mail. Leave host empty to log links instead.
THESADA_SMTP_HOST=
THESADA_SMTP_PORT=587
THESADA_SMTP_USER=
THESADA_SMTP_PASS=
THESADA_SMTP_FROM=

# Optional Telegram alert fan-out.
THESADA_TELEGRAM_BOT_TOKEN=
